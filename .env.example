# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://passly:passly@db:5432/passly
POSTGRES_USER=passly
POSTGRES_PASSWORD=passly
POSTGRES_DB=passly

# ── Gemini / Vertex AI ────────────────────────────────────────────────────────
# USE_VERTEX_AI=false → 로컬 Gemini API 키 사용
# USE_VERTEX_AI=true  → GCP Vertex AI 사용 (서비스 계정 필요)
USE_VERTEX_AI=false
GEMINI_API_KEY=your-gemini-api-key-here

# ── GCP (USE_VERTEX_AI=true 시 필요) ─────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast3

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_TYPE=local → 로컬 파일시스템 / gcs → Google Cloud Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
GCS_BUCKET_NAME=your-bucket-name

# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000
ENV=development
LOG_LEVEL=info
